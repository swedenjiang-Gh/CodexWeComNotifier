<?xml version="1.0" encoding="utf-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="Codex 企业微信通知"
    Manufacturer="CodexWeComNotifier"
    Version="1.1.1"
    Language="2052"
    UpgradeCode="B68341FD-D6A1-4BBC-AAE8-872D9654E2D4"
    Scope="perUser"
    InstallerVersion="500">

    <SummaryInformation Description="Codex 任务完成后发送企业微信群机器人通知" />
    <MajorUpgrade DowngradeErrorMessage="已经安装了更新版本的 Codex 企业微信通知。" />
    <MediaTemplate EmbedCab="yes" />

    <Property Id="USERPROFILEFOLDER">
      <RegistrySearch
        Id="UserProfileSearch"
        Root="HKCU"
        Key="Volatile Environment"
        Name="USERPROFILE"
        Type="directory" />
    </Property>

    <Directory Id="USERPROFILEFOLDER">
      <Directory Id="CODEXDIRECTORY" Name=".codex">
        <Directory Id="INSTALLFOLDER" Name="hooks">
          <Component Id="MainComponent" Guid="B391FBB7-BB9A-4132-9984-1E25D29877B7">
            <File
              Id="ConfigureScript"
              Source="$(var.ConfigureScriptSource)"
              Name="configure-wecom.ps1" />
            <File
              Id="NotificationScript"
              Source="$(var.NotificationScriptSource)"
              Name="notify-wecom.ps1" />
          </Component>
        </Directory>
      </Directory>
    </Directory>

    <CustomAction
      Id="ConfigureProduct"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoLogo -NoProfile -ExecutionPolicy Bypass -File &quot;[#ConfigureScript]&quot;"
      Execute="immediate"
      Return="check"
      Impersonate="yes" />

    <CustomAction
      Id="CleanupProduct"
      Directory="INSTALLFOLDER"
      ExeCommand="&quot;[SystemFolder]WindowsPowerShell\v1.0\powershell.exe&quot; -NoLogo -NoProfile -NonInteractive -ExecutionPolicy Bypass -File &quot;[#ConfigureScript]&quot; -Uninstall"
      Execute="immediate"
      Return="ignore"
      Impersonate="yes" />

    <InstallExecuteSequence>
      <Custom Action="ConfigureProduct" After="InstallFiles" Condition="NOT Installed AND NOT WIX_UPGRADE_DETECTED AND ACTION&lt;&gt;&quot;ADMIN&quot; AND UILevel&gt;=4" />
      <Custom Action="CleanupProduct" Before="RemoveFiles" Condition="REMOVE~=&quot;ALL&quot; AND NOT UPGRADINGPRODUCTCODE" />
    </InstallExecuteSequence>

    <Feature Id="ProductFeature" Title="Codex 企业微信通知" Level="1">
      <ComponentRef Id="MainComponent" />
    </Feature>
  </Package>
</Wix>
